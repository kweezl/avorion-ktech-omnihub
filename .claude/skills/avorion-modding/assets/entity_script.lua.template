package.path = package.path .. ";data/scripts/lib/?.lua"

-- Include the helpers your script uses. callable is required if you expose RPC functions.
-- stringutility is required if you use the %_t localization operator.
include("callable")
include("stringutility")
include("utility")

-- DO NOT remove or alter this comment. The C++ engine parses it to determine the script's VM.
-- namespace MyScript
MyScript = {}

-- ── initialize ───────────────────────────────────────────────────────────────
-- Called once on first attach (args = those passed to addScript("path", arg1, arg2, ...)).
-- Also called on restore from disk, but WITHOUT arguments (_restoring = true).
-- Guard first-time setup so it doesn't run again on load.
function MyScript.initialize(arg1, arg2)
    if _restoring then return end

    -- First-time setup here.
    MyScript.someValue = arg1 or 0

    -- Register event callbacks (optional).
    -- Replace "eventName" and "handlerFunctionName" with the desired event and handler.
    -- See references/callbacks.md for the full list of event names.
    -- Entity():registerCallback("onDestroyed", "onMyScriptDestroyed")
end

-- ── getUpdateInterval ────────────────────────────────────────────────────────
-- Return seconds between update() calls. OMIT this function entirely if you
-- don't need periodic updates — an empty update() still consumes CPU.
function MyScript.getUpdateInterval()
    return 1.0
end

-- ── update ───────────────────────────────────────────────────────────────────
-- Called every getUpdateInterval() seconds. Runs on both server and client unless gated.
function MyScript.update(timeStep)
    if not onServer() then return end
    -- Server-side periodic logic here.
end

