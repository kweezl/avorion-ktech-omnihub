-- ── secure ───────────────────────────────────────────────────────────────────
-- Called before save. Return a plain Lua table (no userdata, no functions).
-- Nested tables are fine. Numbers, strings, booleans, nil are fine.
function MyScript.secure()
    return {
        someValue = MyScript.someValue,
    }
end

-- ── restore ──────────────────────────────────────────────────────────────────
-- Called after initialize() on load. `data` is what secure() last returned.
-- Use "or default" for backwards compatibility when adding new fields.
function MyScript.restore(data)
    MyScript.someValue = data.someValue or 0
end

